programa {
  funcao inicio() {
    
    //Declaração de variaveis
    inteiro idade

    //Entrada de dados
    escreva("Programa para mostrar se e Maior ou Menor de idade \n")

    escreva("Digite a sua idade:")
    leia(idade)

    //Usando as estruturas condicionais se/senao
    se(idade >=18){
      escreva("Vocé é maior de idade")
    } senao {
      escreva("Vocé é menor de idade")
    }


  }
}
