<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pão de Queijo da Serra | Sabor Autêntico</title>
    <meta name="description" content="Pão de queijo artesanal, entrega em Toledo-PR. Peça online e receba em casa!">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        amarelo: '#F5C53D', marrom: '#8B4513', creme: '#FFF8E7', marromClaro: '#A66F38'
                    },
                    fontFamily: { sans: ['Segoe UI', 'Roboto', 'sans-serif'] }
                }
            }
        }
    </script>
    <style type="text/tailwindcss">
        @layer utilities {
            .text-shadow { text-shadow: 2px 2px 4px rgba(0,0,0,0.3); }
            .hover-zoom { transition: transform 0.3s ease; }
            .hover-zoom:hover { transform: scale(1.02); }
        }
    </style>
</head>
<body class="bg-creme text-gray-800">

<!-- Cabeçalho com ícone do Carrinho -->
<header class="bg-marrom text-white sticky top-0 z-50 shadow-md">
    <div class="container mx-auto px-4 py-3 flex justify-between items-center">
        <div class="flex items-center gap-2">
            <i class="fa fa-cutlery text-amarelo text-2xl"></i>
            <h1 class="text-xl md:text-2xl font-bold">Pão de Queijo da Serra</h1>
        </div>
        <nav class="hidden md:flex gap-6">
            <a href="#inicio" class="hover:text-amarelo">Início</a>
            <a href="#cardapio" class="hover:text-amarelo">Cardápio</a>
            <a href="#localizacao" class="hover:text-amarelo">Localização</a>
            <a href="#contato" class="hover:text-amarelo">Contato</a>
            <button onclick="abrirCarrinho()" class="relative hover:text-amarelo">
                <i class="fa fa-shopping-cart text-xl"></i>
                <span id="contadorCarrinho" class="absolute -top-2 -right-3 bg-amarelo text-marrom text-xs rounded-full w-5 h-5 flex items-center justify-center">0</span>
            </button>
        </nav>
        <button class="md:hidden text-2xl" id="menuBtn">
            <i class="fa fa-bars"></i>
        </button>
    </div>
    <div id="menuMobile" class="hidden bg-marromClaro md:hidden">
        <div class="container mx-auto px-4 py-3 flex flex-col gap-3">
            <a href="#inicio" class="hover:text-amarelo">Início</a>
            <a href="#cardapio" class="hover:text-amarelo">Cardápio</a>
            <a href="#localizacao" class="hover:text-amarelo">Localização</a>
            <a href="#contato" class="hover:text-amarelo">Contato</a>
            <button onclick="abrirCarrinho()" class="text-left hover:text-amarelo">🛒 Carrinho (<span id="contadorCarrinhoMob">0</span>)</button>
        </div>
    </div>
</header>

<!-- Seção Início -->
<section id="inicio" class="relative h-[60vh] bg-center bg-cover flex items-center" style="background-image: url('https://images.unsplash.com/photo-1595889440112-95737376f278?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');">
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="container mx-auto px-4 relative z-10 text-white">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-shadow">Sabor de Minas em Toledo</h2>
        <p class="text-lg md:text-xl max-w-xl mb-6">Peça online, receba em casa ou retire na loja. Sempre fresquinho!</p>
        <a href="#cardapio" class="bg-amarelo hover:bg-amarelo/90 text-marrom font-semibold px-8 py-3 rounded-lg shadow-lg inline-block">Ver Cardápio</a>
    </div>
</section>

<!-- Cardápio com Botão Adicionar -->
<section id="cardapio" class="py-16 bg-white">
    <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-marrom mb-12">Nosso Cardápio</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Produto 1 -->
            <div class="bg-white rounded-lg shadow-md overflow-hidden hover-zoom">
                <img src="https://images.unsplash.com/photo-1595889440112-95737376f278?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="w-full h-48 object-cover">
                <div class="p-5">
                    <h3 class="text-xl font-semibold text-marrom mb-2">Tradicional</h3>
                    <p class="text-gray-600 mb-3">Muito queijo, receita de família</p>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-xl font-bold text-marrom">R$ 8,00</span>
                        <span class="text-sm text-gray-500">200g</span>
                    </div>
                    <button onclick="adicionarAoCarrinho('Tradicional', 8.00)" class="w-full bg-amarelo hover:bg-amarelo/90 text-marrom font-semibold py-2 rounded">Adicionar ao Carrinho</button>
                </div>
            </div>
            <!-- Produto 2 -->
            <div class="bg-white rounded-lg shadow-md overflow-hidden hover-zoom">
                <img src="https://images.unsplash.com/photo-1565299585323-38d6b0865b47?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="w-full h-48 object-cover">
                <div class="p-5">
                    <h3 class="text-xl font-semibold text-marrom mb-2">Com Requeijão</h3>
                    <p class="text-gray-600 mb-3">Recheado cremoso</p>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-xl font-bold text-marrom">R$ 10,00</span>
                        <span class="text-sm text-gray-500">200g</span>
                    </div>
                    <button onclick="adicionarAoCarrinho('Com Requeijão', 10.00)" class="w-full bg-amarelo hover:bg-amarelo/90 text-marrom font-semibold py-2 rounded">Adicionar ao Carrinho</button>
                </div>
            </div>
            <!-- Produto 3 -->
            <div class="bg-white rounded-lg shadow-md overflow-hidden hover-zoom">
                <img src="https://images.unsplash.com/photo-1544510808-91bcbee1df55?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="w-full h-48 object-cover">
                <div class="p-5">
                    <h3 class="text-xl font-semibold text-marrom mb-2">Família</h3>
                    <p class="text-gray-600 mb-3">Ideal para compartilhar</p>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-xl font-bold text-marrom">R$ 25,00</span>
                        <span class="text-sm text-gray-500">500g</span>
                    </div>
                    <button onclick="adicionarAoCarrinho('Tamanho Família', 25.00)" class="w-full bg-amarelo hover:bg-amarelo/90 text-marrom font-semibold py-2 rounded">Adicionar ao Carrinho</button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- OUTRAS SEÇÕES (Sobre, Localização, Contato) mantidas aqui igual ao anterior -->
<section id="sobre" class="py-16 bg-creme">
    <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-marrom mb-10">Sobre Nós</h2>
        <div class="flex flex-col md:flex-row gap-8 items-center">
            <div class="md:w-1/2">
                <img src="https://images.unsplash.com/photo-1565299585323-38d6b0865b47?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="rounded-lg shadow-md hover-zoom w-full">
            </div>
            <div class="md:w-1/2">
                <h3 class="text-2xl font-semibold text-marrom mb-4">Nossa História</h3>
                <p class="mb-4 text-gray-700">Receita de família desde 2010, feita com queijo de qualidade e sem conservantes.</p>
                <div class="grid grid-cols-2 gap-4 mt-6">
                    <div><i class="fa fa-check text-amarelo mr-2"></i>Ingredientes Naturais</div>
                    <div><i class="fa fa-check text-amarelo mr-2"></i>Produção Diária</div>
                    <div><i class="fa fa-check text-amarelo mr-2"></i>Entrega Rápida</div>
                    <div><i class="fa fa-check text-amarelo mr-2"></i>Retirada na Loja</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- MODAL DO CARRINHO E PEDIDO -->
<div id="modalCarrinho" class="fixed inset-0 bg-black/70 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-lg w-full max-w-2xl max-h-[90vh] overflow-y-auto p-6 relative">
        <button onclick="fecharCarrinho()" class="absolute top-3 right-4 text-2xl text-gray-500 hover:text-red-500">&times;</button>
        <h3 class="text-2xl font-bold text-marrom mb-4">Seu Pedido</h3>

        <div id="listaCarrinho" class="mb-6 space-y-3"></div>

        <div class="border-t pt-4 mb-4">
            <p class="text-lg"><strong>Subtotal:</strong> R$ <span id="subtotal">0,00</span></p>
            <p class="text-lg"><strong>Taxa de Entrega:</strong> R$ <span id="taxaEntrega">5,00</span></p>
            <p class="text-xl font-bold text-marrom mt-2">Total: R$ <span id="totalGeral">0,00</span></p>
        </div>

        <!-- Formulário de Entrega e Pagamento -->
        <h4 class="text-lg font-semibold mb-3">Dados para Entrega</h4>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4">
            <input type="text" id="nome" placeholder="Seu nome completo" class="border p-2 rounded" required>
            <input type="tel" id="telefone" placeholder="WhatsApp (45) 9XXXX-XXXX" class="border p-2 rounded" required>
        </div>
        <input type="text" id="endereco" placeholder="Rua, número, bairro - Toledo-PR" class="border p-2 rounded w-full mb-3" required>
        <input type="text" id="complemento" placeholder="Complemento / Referência" class="border p-2 rounded w-full mb-4">

        <h4 class="text-lg font-semibold mb-2">Forma de Pagamento</h4>
        <select id="pagamento" class="border p-2 rounded w-full mb-4">
            <option value="Dinheiro">Dinheiro</option>
            <option value="Pix">Pix</option>
            <option value="Cartão">Cartão de Crédito/Débito</option>
            <option value="Retirada">Retirada na Loja (sem taxa)</option>
        </select>

        <button onclick="enviarPedidoWhatsApp()" class="w-full bg-marrom hover:bg-marrom/90 text-white py-3 rounded-lg font-semibold">Finalizar Pedido pelo WhatsApp</button>
    </div>
</div>

<!-- Rodapé -->
<footer class="bg-marrom text-white py-6 text-center">
    <div class="container mx-auto px-4">
        <div class="flex justify-center gap-6 text-2xl mb-3">
            <a href="#" class="hover:text-amarelo"><i class="fa fa-whatsapp"></i></a>
            <a href="#" class="hover:text-amarelo"><i class="fa fa-instagram"></i></a>
            <a href="#" class="hover:text-amarelo"><i class="fa fa-facebook"></i></a>
        </div>
        <p>&copy; 2026 Pão de Queijo da Serra | Toledo-PR</p>
    </div>
</footer>

<!-- SCRIPT COMPLETO DO CARRINHO -->
<script>
let carrinho = [];
const TAXA_FIXA = 5.00; // Valor para entrega em Toledo

function adicionarAoCarrinho(nome, preco) {
    const itemExistente = carrinho.find(i => i.nome === nome);
    if (itemExistente) itemExistente.quantidade++;
    else carrinho.push({ nome, preco, quantidade: 1 });
    atualizarCarrinho();
    alert(`${nome} adicionado ao carrinho!`);
}

function atualizarCarrinho() {
    const lista = document.getElementById('listaCarrinho');
    lista.innerHTML = '';
    let subtotal = 0;
    let totalItens = 0;

    carrinho.forEach((item, idx) => {
        const valor = item.preco * item.quantidade;
        subtotal += valor;
        totalItens += item.quantidade;
        lista.innerHTML += `
        <div class="flex justify-between items-center border-b pb-2">
            <span>${item.nome}</span>
            <div class="flex items-center gap-2">
                <button onclick="alterarQtd(${idx},-1)" class="px-2 bg-gray-200 rounded">-</button>
                <span>${item.quantidade}</span>
                <button onclick="alterarQtd(${idx},1)" class="px-2 bg-gray-200 rounded">+</button>
                <span>R$ ${valor.toFixed(2).replace('.', ',')}</span>
                <button onclick="removerItem(${idx})" class="text-red-500 ml-2">&times;</button>
            </div>
        </div>`;
    });

    let taxa = document.getElementById('pagamento')?.value === 'Retirada' ? 0 : TAXA_FIXA;
    document.getElementById('subtotal').innerText = subtotal.toFixed(2).replace('.', ',');
    document.getElementById('taxaEntrega').innerText = taxa.toFixed(2).replace('.', ',');
    document.getElementById('totalGeral').innerText = (subtotal + taxa).toFixed(2).replace('.', ',');
    document.getElementById('contadorCarrinho').innerText = totalItens;
    document.getElementById('contadorCarrinhoMob').innerText = totalItens;
}

function alterarQtd(index, delta) {
    carrinho[index].quantidade += delta;
    if (carrinho[index].quantidade <= 0) removerItem(index);
    atualizarCarrinho();
}

function removerItem(index) {
    carrinho.splice(index, 1);
    atualizarCarrinho();
}

function abrirCarrinho() {
    if (carrinho.length === 0) { alert('Adicione itens primeiro!'); return; }
    document.getElementById('modalCarrinho').classList.remove('hidden');
}

function fecharCarrinho() {
    document.getElementById('modalCarrinho').classList.add('hidden');
}

function enviarPedidoWhatsApp() {
    const nome = document.getElementById('nome').value.trim();
    const telefone = document.getElementById('telefone').value.trim();
    const endereco = document.getElementById('endereco').value.trim();
    const complemento = document.getElementById('complemento').value.trim();
    const pagamento = document.getElementById('pagamento').value;

    if (!nome || !telefone || !endereco) { alert('Preencha todos os campos obrigatórios!'); return; }

    let mensagem = `*NOVO PEDIDO - Pão de Queijo da Serra*%0A%0A`;
    mensagem += `*Cliente:* ${nome}%0A*WhatsApp:* ${telefone}%0A`;
    mensagem += `*Endereço:* ${endereco} ${complemento ? ` - ${complemento}` : ''}%0A`;
    mensagem += `*Pagamento:* ${pagamento}%0A%0A*Itens:*%0A`;

    let subtotal = 0;
    carrinho.forEach(i => {
        const val = i.preco * i.quantidade;
        subtotal += val;
        mensagem += `• ${i.quantidade}x ${i.nome} - R$ ${val.toFixed(2).replace('.', ',')}%0A`;
    });

    const taxa = pagamento === 'Retirada' ? 0 : TAXA_FIXA;
    mensagem += `%0A*Subtotal:* R$ ${subtotal.toFixed(2).replace('.', ',')}%0A`;
    mensagem += `*Taxa de Entrega:* R$ ${taxa.toFixed(2).replace('.', ',')}%0A`;
    mensagem += `*TOTAL:* R$ ${(subtotal + taxa).toFixed(2).replace('.', ',')}`;

    // SUBSTITUA PELO SEU NÚMERO COM DDD: 55 + DDD + NÚMERO
    const numero = '5545999998888';
    const link = `https://wa.me/${numero}?text=${mensagem}`;
    window.open(link, '_blank');
}

// Atualiza taxa ao mudar forma de pagamento
document.addEventListener('change', e => {
    if (e.target.id === 'pagamento') atualizarCarrinho();
});

// Menu mobile
document.getElementById('menuBtn').addEventListener('click', () => {
    document.getElementById('menuMobile').classList.toggle('hidden');
});
</script>

</body>
</html>
