<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pão de Queijo da Serra | Sabor Autêntico</title>
    <meta name="description" content="Pão de queijo artesanal, feito com queijo de qualidade e receita tradicional. Entregamos em Toledo-PR e região.">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        amarelo: '#F5C53D',
                        marrom: '#8B4513',
                        creme: '#FFF8E7',
                        marromClaro: '#A66F38'
                    },
                    fontFamily: {
                        sans: ['Segoe UI', 'Roboto', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style type="text/tailwindcss">
        @layer utilities {
            .content-auto {
                content-visibility: auto;
            }
            .text-shadow {
                text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            }
            .hover-zoom {
                transition: transform 0.3s ease;
            }
            .hover-zoom:hover {
                transform: scale(1.03);
            }
        }
    </style>
</head>
<body class="bg-creme text-gray-800">

    <!-- Cabeçalho e Navegação -->
    <header class="bg-marrom text-white sticky top-0 z-50 shadow-md">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <i class="fa fa-cutlery text-amarelo text-2xl"></i>
                <h1 class="text-xl md:text-2xl font-bold">Pão de Queijo da Serra</h1>
            </div>
            <nav class="hidden md:flex gap-6">
                <a href="#inicio" class="hover:text-amarelo transition-colors">Início</a>
                <a href="#sobre" class="hover:text-amarelo transition-colors">Sobre Nós</a>
                <a href="#cardapio" class="hover:text-amarelo transition-colors">Cardápio</a>
                <a href="#localizacao" class="hover:text-amarelo transition-colors">Localização</a>
                <a href="#contato" class="hover:text-amarelo transition-colors">Contato</a>
            </nav>
            <button class="md:hidden text-2xl" id="menuBtn">
                <i class="fa fa-bars"></i>
            </button>
        </div>
        <!-- Menu Mobile -->
        <div id="menuMobile" class="hidden bg-marromClaro md:hidden">
            <div class="container mx-auto px-4 py-3 flex flex-col gap-3">
                <a href="#inicio" class="hover:text-amarelo">Início</a>
                <a href="#sobre" class="hover:text-amarelo">Sobre Nós</a>
                <a href="#cardapio" class="hover:text-amarelo">Cardápio</a>
                <a href="#localizacao" class="hover:text-amarelo">Localização</a>
                <a href="#contato" class="hover:text-amarelo">Contato</a>
            </div>
        </div>
    </header>

    <!-- Seção Início -->
    <section id="inicio" class="relative h-[70vh] bg-center bg-cover flex items-center" style="background-image: url('https://images.unsplash.com/photo-1595889440112-95737376f278?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');">
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="container mx-auto px-4 relative z-10 text-white">
            <h2 class="text-4xl md:text-5xl font-bold mb-4 text-shadow">Sabor Tradicional de Minas</h2>
            <p class="text-lg md:text-xl max-w-xl mb-6">Pão de queijo artesanal, feito com receita de família e ingredientes selecionados. Quente, macio e com muito queijo!</p>
            <a href="#cardapio" class="bg-amarelo hover:bg-amarelo/90 text-marrom font-semibold px-8 py-3 rounded-lg shadow-lg inline-block transition-colors">Ver Cardápio</a>
        </div>
    </section>

    <!-- Seção Sobre Nós -->
    <section id="sobre" class="py-16 bg-white">
        <div class="container mx-auto px-4">
            <h2 class="text-3xl font-bold text-center text-marrom mb-10">Sobre Nós</h2>
            <div class="flex flex-col md:flex-row gap-8 items-center">
                <div class="md:w-1/2">
                    <img src="https://images.unsplash.com/photo-1565299585323-38d6b0865b47?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Preparo do pão de queijo" class="rounded-lg shadow-md hover-zoom w-full">
                </div>
                <div class="md:w-1/2">
                    <h3 class="text-2xl font-semibold text-marrom mb-4">Nossa História</h3>
                    <p class="mb-4 text-gray-700">Começamos em 2010, com uma receita passada de geração em geração, levando o sabor autêntico do pão de queijo mineiro para a cidade de Toledo e região.</p>
                    <p class="mb-4 text-gray-700">Usamos apenas queijo de qualidade, polvilho selecionado e sem conservantes artificiais. Nosso compromisso é entregar sempre frescor, sabor e qualidade em cada fornada.</p>
                    <div class="grid grid-cols-2 gap-4 mt-6">
                        <div class="flex items-center gap-2">
                            <i class="fa fa-check-circle text-amarelo text-xl"></i>
                            <span>Ingredientes Naturais</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <i class="fa fa-check-circle text-amarelo text-xl"></i>
                            <span>Receita Tradicional</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <i class="fa fa-check-circle text-amarelo text-xl"></i>
                            <span>Produção Diária</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <i class="fa fa-check-circle text-amarelo text-xl"></i>
                            <span>Entrega Rápida</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Seção Cardápio -->
    <section id="cardapio" class="py-16 bg-creme">
        <div class="container mx-auto px-4">
            <h2 class="text-3xl font-bold text-center text-marrom mb-12">Nosso Cardápio</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Item 1 -->
                <div class="bg-white rounded-lg shadow-md overflow-hidden hover-zoom">
                    <img src="https://images.unsplash.com/photo-1595889440112-95737376f278?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Pão de Queijo Tradicional" class="w-full h-48 object-cover">
                    <div class="p-5">
                        <h3 class="text-xl font-semibold text-marrom mb-2">Tradicional</h3>
                        <p class="text-gray-600 mb-3">O clássico: muito queijo, sabor autêntico e textura perfeita.</p>
                        <div class="flex justify-between items-center font-semibold">
                            <span class="text-marrom">A partir de R$ 8,00</span>
                            <span class="text-sm text-gray-500">Embalagem com 200g</span>
                        </div>
                    </div>
                </div>
                <!-- Item 2 -->
                <div class="bg-white rounded-lg shadow-md overflow-hidden hover-zoom">
                    <img src="https://images.unsplash.com/photo-1565299585323-38d6b0865b47?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Pão de Queijo com Requeijão" class="w-full h-48 object-cover">
                    <div class="p-5">
                        <h3 class="text-xl font-semibold text-marrom mb-2">Com Requeijão</h3>
                        <p class="text-gray-600 mb-3">Recheado com requeijão cremoso, derrete na boca.</p>
                        <div class="flex justify-between items-center font-semibold">
                            <span class="text-marrom">A partir de R$ 10,00</span>
                            <span class="text-sm text-gray-500">Embalagem com 200g</span>
                        </div>
                    </div>
                </div>
                <!-- Item 3 -->
                <div class="bg-white rounded-lg shadow-md overflow-hidden hover-zoom">
                    <img src="https://images.unsplash.com/photo-1544510808-91bcbee1df55?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Pão de Queijo Grande" class="w-full h-48 object-cover">
                    <div class="p-5">
                        <h3 class="text-xl font-semibold text-marrom mb-2">Tamanho Família</h3>
                        <p class="text-gray-600 mb-3">Ideal para compartilhar, com a mesma qualidade e sabor.</p>
                        <div class="flex justify-between items-center font-semibold">
                            <span class="text-marrom">A partir de R$ 25,00</span>
                            <span class="text-sm text-gray-500">Embalagem com 500g</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Seção Localização -->
    <section id="localizacao" class="py-16 bg-white">
        <div class="container mx-auto px-4">
            <h2 class="text-3xl font-bold text-center text-marrom mb-10">Onde Estamos</h2>
            <div class="flex flex-col md:flex-row gap-8">
                <div class="md:w-1/2">
                    <h3 class="text-xl font-semibold mb-4 text-marrom">Endereço e Horário</h3>
                    <div class="space-y-4 text-gray-700">
                        <div class="flex items-start gap-3">
                            <i class="fa fa-map-marker text-amarelo text-2xl mt-1"></i>
                            <div>
                                <p class="font-medium">Rua das Flores, 123 - Centro</p>
                                <p>Toledo - PR, CEP 85900-000</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <i class="fa fa-clock-o text-amarelo text-2xl mt-1"></i>
                            <div>
                                <p class="font-medium">Horário de Atendimento</p>
                                <p>Segunda a Sábado: 7h às 19h</p>
                                <p>Domingos e Feriados: 8h às 12h</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <i class="fa fa-phone text-amarelo text-2xl mt-1"></i>
                            <div>
                                <p class="font-medium">Contato</p>
                                <p>(45) 99999-8888 | (45) 3252-1234</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="md:w-1/2 h-64 bg-gray-200 rounded-lg shadow-md flex items-center justify-center">
                    <p class="text-gray-600">*Aqui você pode inserir o mapa do Google Maps*</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Seção Contato -->
    <section id="contato" class="py-16 bg-creme">
        <div class="container mx-auto px-4">
            <h2 class="text-3xl font-bold text-center text-marrom mb-10">Fale Conosco</h2>
            <div class="max-w-2xl mx-auto bg-white p-8 rounded-lg shadow-md">
                <form action="#" method="POST">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label for="nome" class="block text-gray-700 mb-1">Nome Completo</label>
                            <input type="text" id="nome" name="nome" class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amarelo" required>
                        </div>
                        <div>
                            <label for="telefone" class="block text-gray-700 mb-1">Telefone</label>
                            <input type="tel" id="telefone" name="telefone" class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amarelo" required>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label for="email" class="block text-gray-700 mb-1">E-mail</label>
                        <input type="email" id="email" name="email" class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amarelo">
                    </div>
                    <div class="mb-4">
                        <label for="mensagem" class="block text-gray-700 mb-1">Sua Mensagem / Pedido</label>
                        <textarea id="mensagem" name="mensagem" rows="4" class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-amarelo" required></textarea>
                    </div>
                    <button type="submit" class="w-full bg-marrom hover:bg-marrom/90 text-white font-semibold py-3 rounded-lg transition-colors">Enviar Mensagem</button>
                </form>
            </div>
        </div>
    </section>

    <!-- Rodapé -->
    <footer class="bg-marrom text-white py-8">
        <div class="container mx-auto px-4 text-center">
            <div class="flex justify-center gap-6 text-2xl mb-4">
                <a href="#" class="hover:text-amarelo"><i class="fa fa-facebook"></i></a>
                <a href="#" class="hover:text-amarelo"><i class="fa fa-instagram"></i></a>
                <a href="#" class="hover:text-amarelo"><i class="fa fa-whatsapp"></i></a>
            </div>
            <p>&copy; 2026 Pão de Queijo da Serra. Todos os direitos reservados.</p>
            <p class="text-sm mt-2">Toledo - PR</p>
        </div>
    </footer>

    <!-- Script para Menu Mobile -->
    <script>
        const menuBtn = document.getElementById('menuBtn');
        const menuMobile = document.getElementById('menuMobile');

        menuBtn.addEventListener('click', () => {
            menuMobile.classList.toggle('hidden');
        });

        // Fechar menu ao clicar em um link
        const linksMenu = menuMobile.querySelectorAll('a');
        linksMenu.forEach(link => {
            link.addEventListener('click', () => {
                menuMobile.classList.add('hidden');
            });
        });
    </script>

</body>
</html>
